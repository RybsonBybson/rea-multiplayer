    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "concurrently": "^9.2.1",
    "deep-diff": "^1.0.2",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
